---
import "../styles/monolume.css";
import "../styles/global.css";

interface Props {
  title: string;
  active:
    | "home"
    | "about"
    | "research"
    | "publications"
    | "blog"
    | "get-involved";
}

const { title, active } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header-inner">
          <a class="brand" href="/">
            <svg
              aria-label="RealityFoundation"
              viewBox="0 0 32 32"
              width="22"
              height="22"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              style="display:inline-block;vertical-align:middle;margin-right:0.45rem"
            >
              <rect
                x="2"
                y="2"
                width="28"
                height="28"
                rx="4"
                stroke="currentColor"
                stroke-width="1.5"></rect>
              <path
                d="M8 24 L8 10 L17 10 C20.5 10 22.5 12 22.5 14.5 C22.5 17 20.5 19 17 19 L8 19"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M17 19 L23 24"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"></path>
            </svg>
            RealityFoundation
          </a>
          <nav class="main-nav" aria-label="Main navigation">
            <a href="/" class={active === "home" ? "active" : ""}>Home</a>
            <a href="/about" class={active === "about" ? "active" : ""}>About</a
            >
            <a href="/research" class={active === "research" ? "active" : ""}
              >Research</a
            >
            <a
              href="/publications"
              class={active === "publications" ? "active" : ""}>Publications</a
            >
            <a href="/blog" class={active === "blog" ? "active" : ""}>Blog</a>
            <a
              href="/get-involved"
              class={active === "get-involved" ? "active" : ""}>Get Involved</a
            >
          </nav>
          <button
            class="nav-toggle"
            aria-label="Toggle navigation"
            onclick="this.closest('.site-header').querySelector('.main-nav').classList.toggle('open')"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>
      </header>

      <main class="page">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <span class="footer-brand">RealityFoundation</span>
          <span class="footer-links">
            <a href="/about">About</a>
            <a href="/research">Research</a>
            <a href="/get-involved">Get Involved</a>
          </span>
          <span class="footer-copy">realityfoundation.eu</span>
        </div>
      </footer>
    </div>
  </body>
</html>
