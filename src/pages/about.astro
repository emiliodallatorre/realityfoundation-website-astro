---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/consts";
import Annotation from "@/components/Annotation.astro";
import RoadmapTimeline from "@/components/RoadmapTimeline.astro";
---

<Layout title={SITE.TITLE} description={SITE.DESCRIPTION}>
    <div class="container mx-auto px-6 pt-18">
        <div class="space-y-20 py-12">
            <!-- Mission Section -->
            <section class="space-y-6">
                <h1 class="heading text-4xl md:text-6xl uppercase">Our mission</h1>
                <div class="space-y-4">
                    <p class="text-lg leading-relaxed text-secondary">
                        RealityFoundation is a tech nonprofit based in Brussels and operating across all of Europe. 
                        Our mission is to build the infrastructure to certify and verify the origin of digital content. 
                        As AI makes it effortless to produce convincing images, video, and documents, knowing what is 
                        real has become one of the defining challenges of our era. 
                        We are creating an open and trusted layer for digital media — one that allows anyone to establish 
                        and verify where content comes from. 
                        We are at once a technology organization and a public initiative, 
                        working to ensure that the systems societies depend on, from journalism and justice to commerce and 
                        public debate, can continue to rest on a shared understanding of what is real.
                    </p>
                    <p class="text-lg leading-relaxed text-secondary">
                        We believe that trust in what we see is a public good. 
                        As AI blurs the line between the authentic and the fabricated, that trust cannot hold without a 
                        dependable layer of ground truth beneath our shared reality. RealityFoundation exists to build and protect it.
                    </p>
                </div>
            </section>

            <!-- What We Do Section -->
